# MissionBot configuration sample.
# Copy this to ".env" (gitignored) and fill in real values, then load it into
# the process environment. On the Raspberry Pi this is done by systemd via
#   EnvironmentFile=-/home/pi/MissionBot/.env
# in discordbot.service.

# Discord bot token (REQUIRED). The bot exits at startup if this is unset.
DISCORD_TOKEN=

# Channel ID for the weekly mission auto-post (OPTIONAL).
# If unset, the weekly post is simply not scheduled; all commands still work.
# Enable Developer Mode in Discord, right-click the channel -> Copy Channel ID.
MISSION_CHANNEL_ID=
